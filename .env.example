# ─────────────────────────────────────────────────────────────────────────────
#  APEX — environment template
#  Copy to .env and fill in real values:  cp .env.example .env
#  .env is gitignored — NEVER commit real secrets.
#
#  These are the secrets that deploy.sh pushes to Supabase Edge Functions via
#  `supabase secrets set`. Set them here for `./deploy.sh` to pick up.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (AI features) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Coach portal password (also used as the X-Coach-Token for coach AI calls) ─
# Use a long, random value (>8 chars enforced server-side).
COACH_SECRET=change-me-to-a-long-random-string

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Hosted Stripe Payment Links, one per plan:
STRIPE_LINK_CORE=https://buy.stripe.com/...
STRIPE_LINK_ELITE=https://buy.stripe.com/...
STRIPE_LINK_VIP=https://buy.stripe.com/...
STRIPE_LINK_DIAMOND=https://buy.stripe.com/...
# Optional AI add-on link:
STRIPE_LINK_APEX_AI_FEATURES=https://buy.stripe.com/...
# Customer billing portal (so users can manage/cancel their subscription):
STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/...

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── CORS / origin lock ───────────────────────────────────────────────────────
# The exact origin your frontend is served from. Edge functions reject other
# origins. For GitHub Pages this is your Pages URL (no trailing slash).
ALLOWED_ORIGIN=https://fitfriendchris.github.io

# ─────────────────────────────────────────────────────────────────────────────
#  NOTE: SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are
#  injected into Edge Functions automatically by Supabase — you do NOT need to
#  set them here. get-config reads SUPABASE_URL / SUPABASE_ANON_KEY from that
#  built-in environment and serves them to the browser.
# ─────────────────────────────────────────────────────────────────────────────
